# ── Banco de dados (Supabase) ──────────────────────────────────────────────
# URL do pooler (usada em runtime)
DATABASE_URL="postgresql://postgres.xxxx:senha@aws-0-us-west-2.pooler.supabase.com:5432/postgres"
# URL direta (usada pelo prisma migrate deploy na inicialização)
DIRECT_URL="postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres"

# ── Supabase Storage (para modelos ML) ────────────────────────────────────
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Aplicação ──────────────────────────────────────────────────────────────
APP_URL="https://seudominio.com"
NEXT_PUBLIC_API_URL="https://seudominio.com/api"

# ── Better-Auth ────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://seudominio.com/auth/google/callback"

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=""
