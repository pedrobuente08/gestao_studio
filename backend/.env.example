# ============================================================
# INKSTUDIO - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais
# ============================================================

# ============================================================
# OBRIGATÓRIAS
# ============================================================

# URL de conexão com o banco de dados PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Exemplo: postgresql://postgres:senha123@localhost:5432/inkstudio
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nome_do_banco"
# Supabase + Prisma (schema com directUrl): use pooler nas duas — evita host db.*.supabase.co em redes só IPv4.
# DATABASE_URL = Transaction pooler :6543 + ?pgbouncer=true&sslmode=require (user postgres.PROJECT_REF)
# DIRECT_URL   = Session pooler :5432 + ?sslmode=require (mesmo user e região que no painel Supabase → Connect → Prisma)
# DIRECT_URL="postgresql://postgres.SEU_REF:senha@aws-0-REGIAO.pooler.supabase.com:5432/postgres?sslmode=require"

# ============================================================
# OPCIONAIS - Configuração do Servidor
# ============================================================

# Porta em que o backend vai rodar (padrão: 3001)
PORT=3001

# ============================================================
# OPCIONAIS - Better-Auth
# ============================================================

# Secret para o Better-Auth (recomendado para produção)
# Gere um secret seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""

# URL pública do FRONT (sem barra no fim). Obrigatório em produção para CORS + Better Auth (login Google).
# Ex.: https://tattoohubink.cloud
APP_URL="http://localhost:3000"

# URL pública da API onde o Better Auth está montado (sem barra no fim).
# Ex.: https://api.tattoohubink.cloud
BETTER_AUTH_URL="http://localhost:3001"

# Cookie partilhado entre subdomínios (com ponto inicial). Ex.: .tattoohubink.cloud
# COOKIE_DOMAIN=.tattoohubink.cloud

# Origens extra (vírgula), ex.: https://www.tattoohubink.cloud
# EXTRA_TRUSTED_ORIGINS=

# ============================================================
# OPCIONAIS - OAuth Google (para login com Google)
# ============================================================

# Client ID do Google OAuth
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""

# Client Secret do Google OAuth
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET=""

# URL de callback do Google OAuth
# Padrão: http://localhost:3000/auth/google/callback
# Em produção, use sua URL real: https://seudominio.com/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# ============================================================
# OPCIONAIS - ML Service (CatBoost)
# ============================================================

# URL do microserviço Python de ML
# Em desenvolvimento local: http://localhost:8001
# Em produção (Docker interno): http://ml-service:8001
ML_SERVICE_URL="http://localhost:8001"

# ============================================================
# INSTRUÇÕES
# ============================================================
#
# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Preencha os valores obrigatórios (DATABASE_URL)
#
# 3. Para OAuth Google:
#    - Acesse https://console.cloud.google.com/
#    - Crie um projeto ou selecione um existente
#    - Vá em "APIs & Services" > "Credentials"
#    - Clique em "Create Credentials" > "OAuth client ID"
#    - Configure as URLs autorizadas e callbacks
#    - Copie o Client ID e Client Secret para as variáveis acima
#
# 4. Para gerar um BETTER_AUTH_SECRET seguro:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ============================================================
